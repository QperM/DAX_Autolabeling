# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
.out/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Database (SQLite)
# 运行时库默认路径为项目根目录 database/annotations.db（见 server/db/connection.js）
# 勿提交整个 database 目录；全局 *.db 防止其它路径误提交数据库文件
database/
*.sqlite
*.db

# Logs
logs/
*.log

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/

# Temporary folders
tmp/
temp/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
Thumbs.db
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# Package lock files (uncomment if you want to commit them)
# package-lock.json
# yarn.lock

# Typescript build artifacts
*.tsbuildinfo

# Vite cache
.vite/

# Local development files
*.local

# Uploaded runtime files (should not be committed)
server/uploads/

# Python（sam2-service / pose-service 等）
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
*.egg-info/
.eggs/

# Embedded SAM2 / checkpoints（仅本地使用，不入 Git）
server/sam2-service/grounded-sam2/
*.pt

# Large local artifacts / images (do not commit)
*.tar
*.tar.gz
*.tgz
*.tar.bz2
*.tar.xz
